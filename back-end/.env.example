# Ambiente da aplicação
# Valores: development, production, staging
NODE_ENV=development

# Banco de dados (Prisma)
# Formato: postgresql://usuario:senha@host:porta/banco_dados
# Exemplo PostgreSQL local: postgresql://postgres:senha@localhost:5432/casa-do-hamburger
# Exemplo PostgreSQL remoto (Neon): postgresql://usuario:senha@ep-xxxxx.neon.tech/banco_dados?sslmode=require
DATABASE_URL=postgresql://usuario:senha@localhost:5432/casa-do-hamburger

# JWT (JSON Web Token)
# Chave secreta para assinar tokens JWT
# Use uma string aleatória e complexa em produção (min. 32 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_super_segura_aqui_min_32_caracteres

# Cloudinary (Upload de imagens)
# Crie uma conta em https://cloudinary.com
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
