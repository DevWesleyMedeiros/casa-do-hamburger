generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  cep      String
  admin Boolean @default(false)
}

model Products {
  id String @id @default(cuid())
  name String
  Description String
  price Int
  img String
  createAt DateTime @default(now())
}