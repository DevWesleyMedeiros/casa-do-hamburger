generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  cep      String
  password String
  admin    Boolean @default(false)
}

model Products {
  id          String  @id @default(cuid())
  name        String
  description String
  price       Int
  img         String
  createAt    DateTime @default(now())
}
